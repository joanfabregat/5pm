{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "6pm",
  "version": "0.1.0",
  "identifier": "com.6pm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "6pm",
        "width": 420,
        "height": 220,
        "resizable": true,
        "minWidth": 280,
        "minHeight": 180,
        "center": true,
        "visible": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/joanfabregat/6pm/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1RDg0MzZFOTREQUUyNTkKUldSWjR0cVVia1BZWlQrLzB5L2Z1Y0dsSjBlTG40L25sL080TUVkTVAreFNmSDU2ZERLZG9QQ2kK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
